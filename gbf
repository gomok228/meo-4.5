using UnityEngine;

[RequireComponent(typeof(Rigidbody))]
public class PrototypeCar : MonoBehaviour
{
    [Header("Колеса (перетащи сюда свои WheelColliders)")]
    public WheelCollider[] frontWheels;
    public WheelCollider[] rearWheels;

    [Header("Настройки езды")]
    public float motorTorque = 2000f;
    public float brakeTorque = 3000f;
    public float maxSteerAngle = 25f;
    public float downforcePower = 100f;

    private Rigidbody rb;
    private float startupTimer = 0f;
    private bool isPhysicsReady = false;

    void Start()
    {
        rb = GetComponent<Rigidbody>();
        
        // КАРДИНАЛЬНОЕ РЕШЕНИЕ 1: Жестко задаем массу, чтобы не было сюрпризов
        rb.mass = 1200f;
        rb.linearDamping = 0.05f; // Небольшое сопротивление воздуха
        rb.angularDamping = 0.5f; // Чтобы тачку меньше крутило в воздухе

        // КАРДИНАЛЬНОЕ РЕШЕНИЕ 2: Центр масс ставим точно в геометрический центр, 
        // но чуть-чуть ниже (всего на 10-20 см), чтобы не переворачивалась.
        rb.centerOfMass = new Vector3(0, -0.2f, 0);

        SetupSuspension();
    }

    void SetupSuspension()
    {
        foreach (var wheel in GetComponentsInChildren<WheelCollider>())
        {
            // Делаем среднюю подвеску: не мягкую, но и не каменную
            wheel.suspensionDistance = 0.15f; 
            
            JointSpring spring = wheel.suspensionSpring;
            spring.spring = 40000f; // Оптимально для 1200кг
            spring.damper = 4000f;  // Хорошее гашение ударов
            spring.targetPosition = 0.5f;
            
            wheel.suspensionSpring = spring;
        }
    }

    void FixedUpdate()
    {
        // КАРДИНАЛЬНОЕ РЕШЕНИЕ 3: "Мягкий вход" в игру
        // Первые 0.5 сек только даем машине упасть на пол
        if (!isPhysicsReady)
        {
            startupTimer += Time.fixedDeltaTime;
            if (startupTimer > 0.5f) isPhysicsReady = true;
            return; 
        }

        float v = Input.GetAxis("Vertical");
        float h = Input.GetAxis("Horizontal");

        // Двигатель и тормоза
        foreach (var wheel in rearWheels)
        {
            wheel.motorTorque = v * motorTorque;
            wheel.brakeTorque = Input.GetKey(KeyCode.Space) ? brakeTorque : 0;
        }

        // Поворот
        foreach (var wheel in frontWheels)
        {
            wheel.steerAngle = h * maxSteerAngle;
            wheel.brakeTorque = Input.GetKey(KeyCode.Space) ? brakeTorque : 0;
        }

        // КАРДИНАЛЬНОЕ РЕШЕНИЕ 4: Безопасная прижимная сила
        ApplyStableDownforce();
    }

    void ApplyStableDownforce()
    {
        // Работает только если мы едем быстрее 10 км/ч
        if (rb.linearVelocity.magnitude > 3f)
        {
            // Сила прижима не зависит от квадрата скорости, 
            // чтобы не "раздавить" физику на высоких скоростях
            float stableForce = downforcePower * rb.linearVelocity.magnitude;
            
            // Ограничиваем максимальную силу, чтобы не провалиться сквозь пол
            stableForce = Mathf.Min(stableForce, 15000f); 
            
            rb.AddForce(-transform.up * stableForce);
        }
    }
}
